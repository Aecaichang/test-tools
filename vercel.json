{
  "rewrites": [
    {
      "source": "/shopeeApi",
      "destination": "/api/mock?mock_path=/shopeeApi"
    },
    {
      "source": "/shopeeApi/(.*)",
      "destination": "/api/mock?mock_path=/shopeeApi/$1"
    },
    {
      "source": "/proxy/(.*)",
      "destination": "/api/proxy?_proxy_path=$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
